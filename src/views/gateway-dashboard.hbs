{{! gateway/src/views/gateway-dashboard.hbs }}

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary-subtle">
                <i class="fas fa-users text-primary"></i>
            </div>
            <div class="stat-info">
                <h3 class="mb-0">{{#if stats.patients}}{{stats.patients}}{{else}}0{{/if}}</h3>
                <p class="text-muted mb-0">Total Patients</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-success-subtle">
                <i class="fas fa-heartbeat text-success"></i>
            </div>
            <div class="stat-info">
                <h3 class="mb-0">{{#if stats.ecgRecords.total}}{{stats.ecgRecords.total}}{{else}}0{{/if}}</h3>
                <p class="text-muted mb-0">ECG Records</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning-subtle">
                <i class="fas fa-clock text-warning"></i>
            </div>
            <div class="stat-info">
                <h3 class="mb-0">{{#if stats.ecgRecords.pending}}{{stats.ecgRecords.pending}}{{else}}0{{/if}}</h3>
                <p class="text-muted mb-0">Pending Sync</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-info-subtle">
                <i class="fas fa-cloud-upload-alt text-info"></i>
            </div>
            <div class="stat-info">
                <h3 class="mb-0">{{#if syncStatus.totalSynced}}{{syncStatus.totalSynced}}{{else}}0{{/if}}</h3>
                <p class="text-muted mb-0">Synced Records</p>
            </div>
        </div>
    </div>
</div>

<!-- System Health -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">System Resources</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>CPU Usage</span>
                        <span>{{#if health.system.cpu.usagePercent}}{{health.system.cpu.usagePercent}}%{{else}}0%{{/if}}</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-primary" style="width: {{#if health.system.cpu.usagePercent}}{{health.system.cpu.usagePercent}}{{else}}0{{/if}}%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Memory Usage</span>
                        <span>{{#if health.system.memory.usagePercent}}{{health.system.memory.usagePercent}}%{{else}}0%{{/if}}</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: {{#if health.system.memory.usagePercent}}{{health.system.memory.usagePercent}}{{else}}0{{/if}}%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Storage Usage</span>
                        <span>{{#if health.storage.data.usedPercent}}{{health.storage.data.usedPercent}}%{{else}}0%{{/if}}</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-info" style="width: {{#if health.storage.data.usedPercent}}{{health.storage.data.usedPercent}}{{else}}0{{/if}}%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">System Status</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6 mb-3">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-database fa-2x me-3 text-primary"></i>
                            <div>
                                <div class="fw-bold">Database</div>
                                <small class="text-success">Connected</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 mb-3">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-microscope fa-2x me-3 text-info"></i>
                            <div>
                                <div class="fw-bold">Device Watcher</div>
                                <small class="{{#if deviceStatus.watching}}text-success{{else}}text-warning{{/if}}">
                                    {{#if deviceStatus.watching}}Active{{else}}Waiting{{/if}}
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 mb-3">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-cloud-upload-alt fa-2x me-3 text-success"></i>
                            <div>
                                <div class="fw-bold">Cloud Sync</div>
                                <small class="{{#if syncStatus.isConnected}}text-success{{else}}text-danger{{/if}}">
                                    {{#if syncStatus.isConnected}}Connected{{else}}Offline{{/if}}
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 mb-3">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-exchange-alt fa-2x me-3 text-warning"></i>
                            <div>
                                <div class="fw-bold">HL7 Service</div>
                                <small class="{{#if hl7Enabled}}text-success{{else}}text-secondary{{/if}}">
                                    {{#if hl7Enabled}}Enabled{{else}}Disabled{{/if}}
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Recent ECG Records</h5>
        <a href="/ecg" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>Patient</th>
                        <th>Heart Rate</th>
                        <th>Device</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each recentEcg}}
                    <tr>
                        <td>{{formatDateTime this.recording_time}}</td>
                        <td>
                            <a href="/patients/{{this.patient_id}}" class="text-decoration-none">
                                {{#if this.first_name}}{{this.first_name}} {{/if}}{{#if this.last_name}}{{this.last_name}}{{/if}}
                            </a>
                        </td>
                        <td>{{this.heart_rate}} bpm</td>
                        <td>{{this.device_model}}</td>
                        <td>
                            {{#if this.synced}}
                                <span class="badge bg-success">Synced</span>
                            {{else}}
                                <span class="badge bg-warning">Pending</span>
                            {{/if}}
                        </td>
                        <td>
                            <a href="/ecg/{{this.id}}" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="fas fa-heartbeat fa-3x mb-3 d-block"></i>
                            No ECG records found
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style nonce="{{nonce}}">
.stat-card {
    background: white;
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: transform 0.2s ease;
}

.stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 15px;
}

.stat-icon i {
    font-size: 28px;
}

.stat-info h3 {
    font-size: 28px;
    font-weight: 700;
}

.card {
    border: none;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.card-header {
    background: white;
    border-bottom: 1px solid #e5e7eb;
    padding: 16px 20px;
}

.bg-primary-subtle {
    background: rgba(74,144,226,0.1);
}

.bg-success-subtle {
    background: rgba(16,185,129,0.1);
}

.bg-warning-subtle {
    background: rgba(245,158,11,0.1);
}

.bg-info-subtle {
    background: rgba(14,165,233,0.1);
}

.progress {
    height: 8px;
    border-radius: 4px;
}
</style>

