{{! views/partials/header.hbs }}

<div class="d-flex align-items-center justify-content-between w-100">
    <div class="d-flex align-items-center">
        <button class="btn btn-outline-secondary d-md-none me-3" onclick="toggleSidebar()" style="border: none; background: transparent;">
            <i class="fas fa-bars fs-4"></i>
        </button>
        <h5 class="mb-0 text-dark">
            <i class="fas {{#if (eq active 'dashboard')}}fa-tachometer-alt{{else if (eq active 'patients')}}fa-users{{else if (eq active 'ecg')}}fa-heartbeat{{else}}fa-chart-line{{/if}} me-2" style="color: #4A90E2;"></i>
            {{#if title}}{{title}}{{else}}Dashboard{{/if}}
        </h5>
    </div>

    <div class="d-flex align-items-center gap-3">
        <!-- System Status -->
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" style="border-radius: 20px;">
                <i class="fas fa-circle me-1" style="color: {{#if syncStatus.isConnected}}#10B981{{else}}#EF4444{{/if}}; font-size: 10px;"></i>
                <span>{{#if syncStatus.isConnected}}Connected{{else}}Offline{{/if}}</span>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
                <div class="px-3 py-2">
                    <div class="small">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Cloud Status:</span>
                            <span>{{#if syncStatus.isConnected}}Connected{{else}}Disconnected{{/if}}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Last Sync:</span>
                            <span>{{#if syncStatus.lastSync}}{{formatTimeAgo syncStatus.lastSync}}{{else}}Never{{/if}}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Pending:</span>
                            <span class="fw-bold">{{#if stats.ecgRecords.pending}}{{stats.ecgRecords.pending}}{{else}}0{{/if}}</span>
                        </div>
                        <div class="progress mb-2" style="height: 4px;">
                            <div class="progress-bar bg-info" style="width: {{#if health.storage.data.usedPercent}}{{health.storage.data.usedPercent}}{{else}}0{{/if}}%"></div>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Storage:</span>
                            <span>{{#if health.storage.data.used}}{{health.storage.data.used}}{{else}}0{{/if}} / {{#if health.storage.data.total}}{{health.storage.data.total}}{{else}}0{{/if}}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="dropdown">
            <button class="btn btn-primary btn-sm" type="button" data-bs-toggle="dropdown" style="border-radius: 20px; background: linear-gradient(135deg, #4A90E2 0%, #7EC8FF 100%); border: none;">
                <i class="fas fa-plus me-1"></i>Actions
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="#" onclick="showAddPatientModal()"><i class="fas fa-user-plus me-2 text-primary"></i>Add Patient</a></li>
                <li><a class="dropdown-item" href="#" onclick="forceSync()"><i class="fas fa-sync me-2 text-success"></i>Force Sync</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/logs"><i class="fas fa-history me-2 text-info"></i>View Logs</a></li>
            </ul>
        </div>

        <!-- Logout -->
        <button class="btn btn-outline-danger btn-sm" id="headerLogoutBtn" style="border-radius: 20px;">    
            <i class="fas fa-sign-out-alt me-1"></i>
            <span class="d-none d-sm-inline">Logout</span>
        </button>
    </div>
</div>