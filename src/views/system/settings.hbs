<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gateway Settings</h2>
    <button class="btn btn-primary" onclick="saveSettings()">
        <i class="fas fa-save me-2"></i>Save Changes
    </button>
</div>

<div class="row">
    <!-- General Settings -->
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">General Configuration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Tenant ID</label>
                    <input type="text" class="form-control" id="tenantId" value="{{config.tenantId}}" readonly>
                    <small class="text-muted">This cannot be changed</small>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Hospital Name</label>
                    <input type="text" class="form-control" id="hospitalName" value="{{hospitalName}}">
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Cloud URL</label>
                    <input type="url" class="form-control" id="cloudUrl" value="{{config.cloudUrl}}">
                </div>
            </div>
        </div>
    </div>

    <!-- Sync Settings -->
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Sync Configuration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Sync Interval (minutes)</label>
                    <input type="number" class="form-control" id="syncInterval" value="{{config.syncInterval}}" min="1" max="60">
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Auto Update</label>
                    <select class="form-select" id="autoUpdate">
                        <option value="true" {{#if config.autoUpdate}}selected{{/if}}>Enabled</option>
                        <option value="false" {{#unless config.autoUpdate}}selected{{/unless}}>Disabled</option>
                    </select>
                </div>
                
                <div class="mb-3">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="forceSync" 
                               {{#if syncStatus.isConnected}}checked{{/if}}>
                        <label class="form-check-label" for="forceSync">
                            Force sync now
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Storage Settings -->
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Storage Configuration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Drop Folder</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="dropFolder" value="{{config.dropFolder}}" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="browseFolder()">
                            <i class="fas fa-folder-open"></i>
                        </button>
                    </div>
                    <small class="text-muted">Location for Mindray ECG exports</small>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Data Retention (days)</label>
                    <input type="number" class="form-control" id="retentionDays" value="30" min="1" max="365">
                </div>
                
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Storage Usage:</strong> {{health.storage.data.used}} / {{health.storage.data.total}}
                    <div class="progress mt-2">
                        <div class="progress-bar {{progressBarColor health.storage.data.usedPercent}}" 
                             style="width: {{health.storage.data.usedPercent}}%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- HL7 Settings -->
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">HL7 Integration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">HL7 Enabled</label>
                    <select class="form-select" id="hl7Enabled">
                        <option value="true" {{#if config.hl7Enabled}}selected{{/if}}>Enabled</option>
                        <option value="false" {{#unless config.hl7Enabled}}selected{{/unless}}>Disabled</option>
                    </select>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">HL7 Port</label>
                    <input type="number" class="form-control" id="hl7Port" value="{{config.hl7Port}}" min="1024" max="65535">
                </div>
                
                <div class="mb-3">
                    <label class="form-label">EMR Host</label>
                    <input type="text" class="form-control" id="emrHost" value="localhost">
                </div>
                
                <div class="mb-3">
                    <label class="form-label">EMR Port</label>
                    <input type="number" class="form-control" id="emrPort" value="2575">
                </div>
            </div>
        </div>
    </div>

    <!-- Logging Settings -->
    <div class="col-md-12 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Logging Configuration</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <label class="form-label">Log Level</label>
                        <select class="form-select" id="logLevel">
                            <option value="error" {{#if (eq config.logLevel 'error')}}selected{{/if}}>Error</option>
                            <option value="warn" {{#if (eq config.logLevel 'warn')}}selected{{/if}}>Warning</option>
                            <option value="info" {{#if (eq config.logLevel 'info')}}selected{{/if}}>Info</option>
                            <option value="debug" {{#if (eq config.logLevel 'debug')}}selected{{/if}}>Debug</option>
                        </select>
                    </div>
                    
                    <div class="col-md-4">
                        <label class="form-label">Log Retention (days)</label>
                        <input type="number" class="form-control" id="logRetention" value="30" min="1" max="365">
                    </div>
                    
                    <div class="col-md-4">
                        <label class="form-label">Max Log Size (MB)</label>
                        <input type="number" class="form-control" id="logMaxSize" value="10" min="1" max="100">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

 <script nonce="{{nonce}}">
async function saveSettings() {
    const settings = {
        hospitalName: document.getElementById('hospitalName').value,
        cloudUrl: document.getElementById('cloudUrl').value,
        syncInterval: parseInt(document.getElementById('syncInterval').value) * 60000,
        autoUpdate: document.getElementById('autoUpdate').value === 'true',
        dropFolder: document.getElementById('dropFolder').value,
        retentionDays: parseInt(document.getElementById('retentionDays').value),
        hl7Enabled: document.getElementById('hl7Enabled').value === 'true',
        hl7Port: parseInt(document.getElementById('hl7Port').value),
        emrHost: document.getElementById('emrHost').value,
        emrPort: parseInt(document.getElementById('emrPort').value),
        logLevel: document.getElementById('logLevel').value,
        logRetention: parseInt(document.getElementById('logRetention').value),
        logMaxSize: parseInt(document.getElementById('logMaxSize').value)
    };
    
    // Handle force sync
    if (document.getElementById('forceSync').checked) {
        try {
            await fetch('/api/local/sync/force', { method: 'POST' });
        } catch (error) {
            console.error('Force sync failed:', error);
        }
    }
    
    try {
        const response = await fetch('/api/local/settings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(settings)
        });
        
        const data = await response.json();
        
        if (data.success) {
            showNotification('Settings saved successfully', 'success');
        } else {
            showNotification('Error: ' + data.error, 'danger');
        }
    } catch (error) {
        showNotification('Failed to save settings', 'danger');
    }
}

function browseFolder() {
    // In a real implementation, this would open a folder browser
    // For now, just show a message
    alert('Folder browsing is not available in this demo');
}

function showNotification(message, type) {
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 end-0 m-3`;
    alertDiv.style.zIndex = '9999';
    alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    document.body.appendChild(alertDiv);
    setTimeout(() => alertDiv.remove(), 5000);
}
</script>