{{! gateway/src/views/patient-view.hbs }}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Patient Details</h2>
    <div>
        <a href="/patients" class="btn btn-outline-secondary me-2">
            <i class="fas fa-arrow-left me-2"></i>Back to Patients
        </a>
        <a href="/patients/{{patient.id}}/edit" class="btn btn-primary">
            <i class="fas fa-edit me-2"></i>Edit Patient
        </a>
    </div>
</div>

<div class="row">
    <!-- Patient Information Card -->
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">Patient Information</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Medical Record Number:</strong>
                    <p class="mb-0"><code>{{patient.medicalRecordNumber}}</code></p>
                </div>
                <div class="mb-3">
                    <strong>Full Name:</strong>
                    <p class="mb-0">{{patient.firstName}} {{patient.lastName}}</p>
                </div>
                <div class="mb-3">
                    <strong>Date of Birth:</strong>
                    <p class="mb-0">{{formatDate patient.dateOfBirth}}</p>
                </div>
                <div class="mb-3">
                    <strong>Age:</strong>
                    <p class="mb-0">{{calculateAge patient.dateOfBirth}} years</p>
                </div>
                <div class="mb-3">
                    <strong>Gender:</strong>
                    <p class="mb-0">{{patient.gender}}</p>
                </div>
                <div class="mb-3">
                    <strong>Status:</strong>
                    <p class="mb-0">
                        <span class="badge bg-{{#if (eq patient.status 'active')}}success{{else}}secondary{{/if}}">
                            {{patient.status}}
                        </span>
                    </p>
                </div>
                <div class="mb-3">
                    <strong>Sync Status:</strong>
                    <p class="mb-0">
                        {{#if patient.synced}}
                            <span class="badge bg-success">Synced to Cloud</span>
                        {{else}}
                            <span class="badge bg-warning">Local Only</span>
                        {{/if}}
                    </p>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Contact Information Card -->
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">Contact Information</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Phone:</strong>
                    <p class="mb-0">{{#if patient.phone}}{{patient.phone}}{{else}}<span class="text-muted">Not provided</span>{{/if}}</p>
                </div>
                <div class="mb-3">
                    <strong>Email:</strong>
                    <p class="mb-0">{{#if patient.email}}{{patient.email}}{{else}}<span class="text-muted">Not provided</span>{{/if}}</p>
                </div>
                <div class="mb-3">
                    <strong>Address:</strong>
                    <p class="mb-0">{{#if patient.address}}{{patient.address}}{{else}}<span class="text-muted">Not provided</span>{{/if}}</p>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Statistics Card -->
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">ECG Statistics</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Total ECG Records:</strong>
                    <p class="mb-0">{{ecgStats.total}}</p>
                </div>
                <div class="mb-3">
                    <strong>Latest Heart Rate:</strong>
                    <p class="mb-0">{{#if ecgStats.latestHeartRate}}{{ecgStats.latestHeartRate}} bpm{{else}}No data{{/if}}</p>
                </div>
                <div class="mb-3">
                    <strong>Latest Recording:</strong>
                    <p class="mb-0">{{#if ecgStats.latestRecording}}{{formatDateTime ecgStats.latestRecording}}{{else}}No data{{/if}}</p>
                </div>
                <div class="mt-3">
                    <a href="/ecg?patient={{patient.id}}" class="btn btn-outline-primary w-100">
                        <i class="fas fa-heartbeat me-2"></i>View All ECG Records
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ECG Records Table -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Recent ECG Records</h5>
        <a href="/ecg/upload?patient={{patient.id}}" class="btn btn-sm btn-primary">
            <i class="fas fa-upload me-1"></i>Upload New ECG
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>Heart Rate</th>
                        <th>PR Interval</th>
                        <th>QRS Duration</th>
                        <th>QT Interval</th>
                        <th>Device</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each ecgRecords}}
                    <tr>
                        <td>{{formatDateTime this.recordingTime}}</td>
                        <td>{{#if this.heartRate}}{{this.heartRate}} bpm{{else}}-{{/if}}</td>
                        <td>{{#if this.prInterval}}{{this.prInterval}} ms{{else}}-{{/if}}</td>
                        <td>{{#if this.qrsDuration}}{{this.qrsDuration}} ms{{else}}-{{/if}}</td>
                        <td>{{#if this.qtInterval}}{{this.qtInterval}} ms{{else}}-{{/if}}</td>
                        <td>{{this.deviceModel}}</td>
                        <td>
                            {{#if this.synced}}
                                <span class="badge bg-success">Synced</span>
                            {{else}}
                                <span class="badge bg-warning">Pending</span>
                            {{/if}}
                        </td>
                        <td>
                            <a href="/ecg/{{this.id}}" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <i class="fas fa-heartbeat fa-3x mb-3 d-block"></i>
                            No ECG records found for this patient
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
.card {
    border: none;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.card-header {
    background: white;
    border-bottom: 1px solid #e5e7eb;
    padding: 16px 20px;
    border-radius: 12px 12px 0 0 !important;
}

code {
    background: #f3f4f6;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85rem;
}
</style>