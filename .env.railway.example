# Railway Environment Variables
NODE_ENV=production
PORT=8080

# Gateway Configuration
TENANT_ID=your-tenant-id-here
API_KEY=your-api-key-here
CLOUD_URL=https://api.offinhealthcare.com

# Encryption (generate a secure 32+ character key)
ENCRYPTION_KEY=d2aa4b210c06ff0a7600b9e5873db7e326adea84cf14ed8dfe6482a05502fbf2

# Database Path (Railway specific)
DB_PATH=/app/data/offin.db
RAILWAY_ENVIRONMENT=production

# Disable file-based services on Railway
DEVICE_WATCHER_ENABLED=false
HL7_ENABLED=false
CARDIOSOFT_ENABLED=false

# Sync Settings
SYNC_INTERVAL=300000
SYNC_BATCH_SIZE=100
RETRY_ATTEMPTS=3
RETRY_DELAY=60000

# Logging
LOG_LEVEL=info
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=10

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
HEARTBEAT_INTERVAL=60000