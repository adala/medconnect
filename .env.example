# Gateway Configuration
NODE_ENV=production
GATEWAY_PORT=8080
HL7_PORT=6661

# Tenant Identification (provided by OFFIN Cloud)
TENANT_ID=your-tenant-id-here
API_KEY=2f073ffa4596693a80f3c60bc03644085c09ed8127cc96438b50267705230c8e
CLOUD_URL=https://api.offinhealthcare.com

# Encryption (auto-generated during installation)
ENCRYPTION_KEY=d2aa4b210c06ff0a7600b9e5873db7e326adea84cf14ed8dfe6482a05502fbf2

# Sync Settings
SYNC_INTERVAL=300000  # 5 minutes in milliseconds
SYNC_BATCH_SIZE=100
RETRY_ATTEMPTS=3
RETRY_DELAY=60000     # 1 minute

# Local Storage
DB_PATH=./data/offin.db
DROP_FOLDER=./drop-folder
QUARANTINE_FOLDER=./drop-folder/quarantine
BACKUP_FOLDER=./backups
LOG_FOLDER=./logs

VERCEL=1

# Device Watcher Configuration
DEVICE_WATCHER_DROP_FOLDER=./drop-folder
DEVICE_WATCHER_TELEMETRY_ENABLED=false
DEVICE_WATCHER_VENDOR_CONFIG_PATH=./config

#Email: admin@localhost
#Password: 029f964a38c25023

# Auto-update Settings
AUTO_UPDATE=true
UPDATE_CHECK_INTERVAL=3600000  # 1 hour
ALLOW_BETA_UPDATES=false

# Local Dashboard Authentication
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-please

# HL7 Integration (optional)
HL7_ENABLED=false
HL7_LOCAL_EMR_HOST=localhost
HL7_LOCAL_EMR_PORT=2575
HL7_SENDING_APP=OFFIN_GATEWAY
HL7_SENDING_FACILITY=HOSPITAL

TELEMETRY_ENABLED=false  # Hospitals must explicitly opt-in
TELEMETRY_INTERVAL=3600000  # Sync every hour (1 hour)

# Logging
LOG_LEVEL=info
LOG_MAX_SIZE=10485760  # 10MB
LOG_MAX_FILES=10

# Resource Limits
MAX_CONCURRENT_SYNC=3
MAX_FILE_SIZE=104857600  # 100MB
DISK_WARNING_THRESHOLD=0.9  # 90% full
DISK_CRITICAL_THRESHOLD=0.95  # 95% full

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
HEARTBEAT_INTERVAL=60000  # 1 minute

# Proxy Configuration (if hospital uses proxy)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# XML Parser Configuration
MAX_XML_FILE_SIZE=104857600  # 100MB max file size
STREAMING_THRESHOLD=10485760  # 10MB threshold for streaming
PARSER_CACHE_SIZE=10  # Number of parsed files to cache
XML_PARSER_TIMEOUT=30000  # 30 seconds timeout

# Node.js Memory
NODE_OPTIONS="--max-old-space-size=2048 --expose-gc"