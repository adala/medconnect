{
  "vendors": [
    {
      "name": "CardioSoft",
      "rootElement": "CardiologyXML",
      "detection": {
        "type": "root_element",
        "value": "CardiologyXML"
      },
      "mappings": {
        "patientInfo": {
          "medicalRecordNumber": [
            "PatientInfo.PID",
            "PatientInfo.MRN",
            "PatientInfo.PatientID"
          ],
          "firstName": [
            "PatientInfo.Name.GivenName",
            "PatientInfo.FirstName"
          ],
          "lastName": [
            "PatientInfo.Name.FamilyName",
            "PatientInfo.LastName"
          ],
          "dateOfBirth": {
            "path": "PatientInfo.BirthDateTime",
            "transform": "dateTimeObject",
            "format": "{year}-{month}-{day}"
          },
          "gender": [
            "PatientInfo.Gender"
          ],
          "age": [
            "PatientInfo.Age"
          ]
        },
        "deviceInfo": {
          "deviceId": [
            "ClinicalInfo.DeviceInfo.ID",
            "DeviceInfo.DeviceID"
          ],
          "deviceModel": [
            "ClinicalInfo.DeviceInfo.Desc",
            "DeviceInfo.Desc"
          ],
          "softwareVer": [
            "ClinicalInfo.DeviceInfo.SoftwareVer"
          ],
          "analysisVer": [
            "ClinicalInfo.DeviceInfo.AnalysisVer"
          ]
        },
        "measurements": {
          "heartRate": [
            "ExerciseMeasurements.PeakExHR",
            "ExerciseMeasurements.MaxHeartRate",
            "Measurements.HeartRate"
          ],
          "maxHeartRate": [
            "ExerciseMeasurements.MaxHeartRate"
          ],
          "restingHR": [
            "ExerciseMeasurements.RestingStats.RestHR"
          ],
          "maxWorkload": [
            "ExerciseMeasurements.MaxWorkload"
          ],
          "exerciseTime": [
            "ExerciseMeasurements.ExercisePhaseTime"
          ],
          "prInterval": [
            "Measurements.PRInterval"
          ],
          "qrsDuration": [
            "Measurements.QRSDuration"
          ],
          "qtInterval": [
            "Measurements.QTInterval"
          ],
          "qtcInterval": [
            "Measurements.QTCInterval"
          ]
        },
        "waveform": {
          "paths": [
            "MedianData.Median[0].WaveformData",
            "WaveformData",
            "WaveFormData"
          ],
          "preferred": "MedianData.Median[0].WaveformData"
        },
        "recordingTime": {
          "paths": [
            "ObservationDateTime",
            "Recording.RecordingTime",
            "RecordingTime"
          ],
          "transform": "dateTime"
        }
      }
    },
    {
      "name": "Mindray",
      "rootElement": "ECGReport",
      "detection": {
        "type": "root_element",
        "value": "ECGReport"
      },
      "fallbackRoot": "EcgReport",
      "mappings": {
        "patientInfo": {
          "medicalRecordNumber": [
            "PatientInfo.MRN",
            "PatientInfo.PatientID"
          ],
          "firstName": [
            "PatientInfo.FirstName"
          ],
          "lastName": [
            "PatientInfo.LastName"
          ],
          "dateOfBirth": [
            "PatientInfo.DateOfBirth"
          ],
          "gender": [
            "PatientInfo.Gender"
          ],
          "age": [
            "PatientInfo.Age"
          ]
        },
        "deviceInfo": {
          "deviceId": [
            "DeviceInfo.DeviceID"
          ],
          "deviceModel": [
            "DeviceInfo.DeviceModel"
          ],
          "manufacturer": [
            "DeviceInfo.Manufacturer"
          ]
        },
        "measurements": {
          "heartRate": [
            "Measurements.HeartRate"
          ],
          "prInterval": [
            "Measurements.PRInterval"
          ],
          "qrsDuration": [
            "Measurements.QRSDuration"
          ],
          "qtInterval": [
            "Measurements.QTInterval"
          ],
          "qtcInterval": [
            "Measurements.QTCInterval"
          ]
        },
        "waveform": {
          "paths": [
            "WaveformData",
            "WaveFormData"
          ]
        },
        "recordingTime": {
          "paths": [
            "Recording.RecordingTime",
            "RecordingTime"
          ]
        }
      }
    },
    {
      "name": "GE_MUSE",
      "rootElement": "MuseXML",
      "detection": {
        "type": "root_element",
        "value": "MuseXML"
      },
      "mappings": {
        "patientInfo": {
          "medicalRecordNumber": [
            "PatientDemographics.MRN",
            "Patient.ID"
          ],
          "firstName": [
            "PatientDemographics.FirstName"
          ],
          "lastName": [
            "PatientDemographics.LastName"
          ],
          "dateOfBirth": [
            "PatientDemographics.DOB"
          ],
          "gender": [
            "PatientDemographics.Gender"
          ]
        },
        "deviceInfo": {
          "deviceModel": [
            "AcquisitionInfo.DeviceModel"
          ],
          "softwareVer": [
            "AcquisitionInfo.SoftwareVersion"
          ]
        },
        "measurements": {
          "heartRate": [
            "Measurements.VentricularRate",
            "RestingECG.HeartRate"
          ],
          "prInterval": [
            "Measurements.PRInterval"
          ],
          "qrsDuration": [
            "Measurements.QRSDuration"
          ],
          "qtInterval": [
            "Measurements.QTInterval"
          ]
        },
        "waveform": {
          "paths": [
            "WaveformData.RhythmStrip",
            "ECGWaveform.Data"
          ]
        },
        "recordingTime": {
          "paths": [
            "AcquisitionInfo.AcquisitionTime",
            "Recording.Time"
          ]
        }
      }
    },
    {
      "name": "Philips_IntelliSpace",
      "rootElement": "ECG",
      "detection": {
        "type": "xmlns",
        "value": "http://www.philips.com/ecg"
      },
      "mappings": {
        "patientInfo": {
          "medicalRecordNumber": [
            "Patient.Identifier",
            "Demographics.MRN"
          ],
          "firstName": [
            "Demographics.FirstName"
          ],
          "lastName": [
            "Demographics.LastName"
          ],
          "dateOfBirth": [
            "Demographics.BirthDate"
          ],
          "gender": [
            "Demographics.Gender"
          ]
        },
        "deviceInfo": {
          "deviceId": [
            "Device.SerialNumber"
          ],
          "deviceModel": [
            "Device.Model"
          ]
        },
        "measurements": {
          "heartRate": [
            "Analysis.HeartRate"
          ],
          "prInterval": [
            "Analysis.Intervals.PR"
          ],
          "qrsDuration": [
            "Analysis.Intervals.QRS"
          ],
          "qtInterval": [
            "Analysis.Intervals.QT"
          ],
          "qtcInterval": [
            "Analysis.Intervals.QTc"
          ]
        },
        "waveform": {
          "paths": [
            "Waveforms.Lead"
          ]
        },
        "recordingTime": {
          "paths": [
            "Recording.DateTime"
          ]
        }
      }
    }
  ],
  "global": {
    "arrayTags": [
      "Finding",
      "Lead",
      "Median",
      "TrendEntry"
    ],
    "ignoreAttributes": false,
    "attributeNamePrefix": "@_"
  }
}